# =========================================================================
# AffordMed Campus Notifications Frontend - Configuration Environment Template
# =========================================================================

# The API base endpoint for notifications and evaluation metrics
NEXT_PUBLIC_API_BASE_URL=http://4.224.186.213

# The endpoint where log messages are sent for grading and metrics
NEXT_PUBLIC_LOGS_API_URL=http://4.224.186.213/evaluation-service/logs

# Bearer Token for API authorization. If empty, the app will log to console fallbacks.
# Replace with the access token retrieved from backend authentication.
NEXT_PUBLIC_ACCESS_TOKEN=your_jwt_access_token_here
