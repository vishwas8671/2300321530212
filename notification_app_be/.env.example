# =========================================================================
# AffordMed Campus Notifications Backend - Configuration Environment Template
# =========================================================================

# The API credentials obtained from AffordMed registration.
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# Access Token obtained from POST /evaluation-service/auth.
# This can be set manually, or the tokenManager.js script will fetch it and log it.
ACCESS_TOKEN=your_jwt_access_token_here

# Base URL for the AffordMed Evaluation Service API.
API_BASE_URL=http://4.224.186.213

# Logging Service API Endpoint (Uses standard /logs path of evaluation-service)
LOGS_API_URL=http://4.224.186.213/evaluation-service/logs
